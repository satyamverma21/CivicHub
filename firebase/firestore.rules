rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function currentUser() {
      return userDoc(request.auth.uid).data;
    }

    function currentRole() {
      return isAuthenticated() ? (request.auth.token.role != null ? request.auth.token.role : currentUser().role) : null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && currentRole() == 'SuperAdmin';
    }

    function channelDoc(channelId) {
      return get(/databases/$(database)/documents/channels/$(channelId));
    }

    function isMember(channelId) {
      return isAuthenticated() && (
        currentUser().channelId == channelId ||
        (channelDoc(channelId).data.memberIds is list && channelDoc(channelId).data.memberIds.hasAny([request.auth.uid]))
      );
    }

    function isHead(channelId) {
      return isAuthenticated() && (
        (currentRole() == 'Head' && currentUser().channelId == channelId) ||
        channelDoc(channelId).data.headId == request.auth.uid
      );
    }

    match /channels/{channelId} {
      allow read: if isMember(channelId) || isSuperAdmin();
      allow create: if isAuthenticated() && (currentRole() == 'Head' || isSuperAdmin());
      allow update, delete: if isHead(channelId) || isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (resource.data.channelId != null && isMember(resource.data.channelId))
      );
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    match /issues/{issueId} {
      allow read: if isAuthenticated() && isMember(resource.data.channelId);
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.authorId ||
        currentRole() in ['Authority', 'Head', 'SuperAdmin']
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.authorId ||
        currentRole() in ['Head', 'SuperAdmin']
      );

      match /statusHistory/{entryId} {
        allow read: if isAuthenticated() && isMember(get(/databases/$(database)/documents/issues/$(issueId)).data.channelId);
        allow create: if isAuthenticated();
        allow update, delete: if false;
      }
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        isSuperAdmin()
      );
      allow update: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isSuperAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isSuperAdmin());
    }

    match /progressUpdates/{updateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    match /channelRequests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    match /logs/{logId} {
      allow read, write: if isSuperAdmin();
    }

    match /suspendedUsers/{userId} {
      allow read, write: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
